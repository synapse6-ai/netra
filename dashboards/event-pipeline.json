  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Started /s",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "sum(rate(event_processing_started_total{service=~\"$service\", environment=~\"$environment\", stage=~\"$stage\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
