        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "sum(rate(event_processing_failed_total{service=~\"$service\", environment=~\"$environment\", stage=~\"$stage\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Success ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "100 * sum(rate(event_processing_completed_total{service=~\"$service\", environment=~\"$environment\", stage=~\"$stage\"}[5m])) / clamp_min(sum(rate(event_processing_started_total{service=~\"$service\", environment=~\"$environment\", stage=~\"$stage\"}[5m])), 0.001)",
          "refId": "A"
        }
      ]
    },
    {
