          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(event_processing_stage_duration_seconds_bucket{service=~\"$service\", environment=~\"$environment\", stage=~\"$stage\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
