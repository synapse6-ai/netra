  "tags": [
    "netra",
    "services",
    "dependencies"
  ],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "liveNow": false,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "timezone": "",
  "weekStart": "",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "links": [],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "environment",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "netra-prometheus"
        },
        "definition": "label_values(http_requests_total{scrape_class=\"api\"}, environment)",
        "query": {
          "qryType": 1,
          "query": "label_values(http_requests_total{scrape_class=\"api\"}, environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "includeAll": true,
        "multi": false,
        "refresh": 1,
        "sort": 1,
        "regex": "",
        "skipUrlSync": false,
        "hide": 0,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "DB conns in use",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "max(db_pool_connections{environment=~\"$environment\", state=\"in_use\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DB pool total",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "max(db_pool_connections{environment=~\"$environment\", state=\"total\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DB errors /s",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "sum(rate(db_errors_total{environment=~\"$environment\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Decision-engine err %",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "100 * sum(rate(decision_client_requests_total{environment=~\"$environment\", status=~\"timeout|error\"}[5m])) / clamp_min(sum(rate(decision_client_requests_total{environment=~\"$environment\"}[5m])),0.0001)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DB connection pool by state",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "max by (state) (db_pool_connections{environment=~\"$environment\"})",
          "refId": "A",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DB errors by kind",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "sum by (kind) (rate(db_errors_total{environment=~\"$environment\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Decision-engine client latency",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(decision_client_duration_seconds_bucket{environment=~\"$environment\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(decision_client_duration_seconds_bucket{environment=~\"$environment\"}[5m])))",
          "refId": "B",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Decision-engine client calls by status",
      "datasource": {
        "type": "prometheus",
        "uid": "netra-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "netra-prometheus"
          },
          "expr": "sum by (status) (rate(decision_client_requests_total{environment=~\"$environment\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
