// Synapse6 app-cluster Alloy agent — logs + metrics → central platform.
// Substituted by install-agents.sh (envsubst).

logging {
  level = "info"
}

discovery.kubernetes "pods" {
  role = "pod"
  selectors {
    role  = "pod"
    field = "spec.nodeName=" + sys.env("HOSTNAME")
  }
}

discovery.relabel "pod_logs" {
  targets = discovery.kubernetes.pods.targets

  rule {
    source_labels = ["__meta_kubernetes_namespace"]
    target_label  = "namespace"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_container_name"]
    target_label  = "container"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_name"]
    target_label  = "service_name"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_team"]
    target_label  = "team"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_environment"]
    target_label  = "environment"
  }
  rule {
    target_label = "cluster"
    replacement  = "${K8S_CLUSTER}"
  }
  rule {
    target_label = "environment"
    replacement  = "${ENVIRONMENT}"
    regex        = "^$"
  }
}

loki.source.kubernetes "pods" {
  targets    = discovery.relabel.pod_logs.output
  forward_to = [loki.process.app_logs.receiver]
}

loki.process "app_logs" {
  forward_to = [loki.write.central.receiver]
  stage.json {
    expressions = { level = "level" }
  }
  stage.labels {
    values = { level = "" }
  }
}

loki.write "central" {
  endpoint {
    url          = "${CENTRAL_LOKI_URL}"
    bearer_token = sys.env("INGEST_TOKEN")
  }
  external_labels = {
    cluster     = "${K8S_CLUSTER}",
    environment = "${ENVIRONMENT}",
  }
}

// Scrape endpoints matching Netra ServiceMonitor contract:
//   Service metadata: app.kubernetes.io/component api|worker
//   Port name: http-metrics, path /metrics
//   Pod labels → service, team, environment (mirrors python-api-servicemonitor.yaml)
discovery.kubernetes "endpoints" {
  role = "endpoint"
}

discovery.relabel "metrics" {
  targets = discovery.kubernetes.endpoints.targets

  rule {
    source_labels = ["__meta_kubernetes_endpoint_port_name"]
    regex         = "http-metrics"
    action        = "keep"
  }
  rule {
    source_labels = ["__meta_kubernetes_service_label_app_kubernetes_io_component"]
    regex         = "api|worker"
    action        = "keep"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_name"]
    target_label  = "service"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_team"]
    target_label  = "team"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_environment"]
    target_label  = "environment"
  }
  rule {
    source_labels = ["__meta_kubernetes_namespace"]
    target_label  = "namespace"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }
  rule {
    source_labels = ["__meta_kubernetes_service_label_app_kubernetes_io_component"]
    target_label  = "scrape_class"
  }
  rule {
    target_label = "cluster"
    replacement  = "${K8S_CLUSTER}"
  }
  rule {
    target_label = "environment"
    replacement  = "${ENVIRONMENT}"
    regex        = "^$"
  }
}

prometheus.scrape "apps" {
  targets         = discovery.relabel.metrics.output
  forward_to      = [prometheus.remote_write.central.receiver]
  scrape_interval = "30s"
  metrics_path    = "/metrics"
}

prometheus.remote_write "central" {
  endpoint {
    url          = "${CENTRAL_PROM_REMOTE_WRITE}"
    bearer_token = sys.env("INGEST_TOKEN")
  }
}
